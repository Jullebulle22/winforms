# Normalize line endings: store LF in the repo, check out native on each OS
* text=auto

# C# source and project files
*.cs   text diff=csharp
*.csproj text
*.slnx text
*.sln  text eol=crlf
*.resx text

# Binary files (never touch line endings)
*.png  binary
*.jpg  binary
*.ico  binary
*.pptx binary
*.dll  binary
*.exe  binary
*.pdb  binary
